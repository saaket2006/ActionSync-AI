# ActionSync AI - Environment Configuration Example

# Gemini API Key (Required for Google ADK agents)
GEMINI_API_KEY=your_gemini_api_key_here

# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
SECRET_KEY=your_jwt_secret_key_here_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration
# SQLite (development)
DATABASE_URL=sqlite:///./storage/actionsync.db
# PostgreSQL (production-ready)
# DATABASE_URL=postgresql://user:password@localhost:5432/actionsync

# Model Settings
# Can be gemini-2.5-flash or gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash
WHISPER_MODEL_NAME=base

# Storage Paths (Relative to project root or absolute)
STORAGE_DIR=./storage
UPLOAD_DIR=./storage/uploads
GENERATED_DOCS_DIR=./storage/docs
KNOWLEDGE_GRAPH_PATH=./storage/knowledge_graph.json
